{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user trial and premium status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "firstLoginAt": { "type": "string", "format": "date-time", "description": "Timestamp of the very first login" },
        "isPremium": { "type": "boolean", "description": "Whether the user has paid for full access" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "firstLoginAt", "isPremium"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Individual user profiles"
    }
  }
}
