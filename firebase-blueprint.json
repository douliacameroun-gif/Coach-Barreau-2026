{
  "entities": {
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session between Christiane and the Coach.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user."
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "attachment": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "data": { "type": "string" }
                }
              }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "subject": { "type": "string" }
      },
      "required": ["userId", "messages", "lastUpdated"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Collection of chat sessions."
    }
  }
}
