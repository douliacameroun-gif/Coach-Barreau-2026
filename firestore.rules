rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: discussions
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - User ID
    //   - subjectId: string (required) - Subject identifier
    //   - subjectName: string (optional) - Subject display name
    //   - messages: list (required, max 1000 items) - Chat messages
    //   - updatedAt: timestamp (required) - Last update time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "douliacameroun@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidMessage(msg) {
      return msg is map &&
             msg.role in ['user', 'model'] &&
             msg.content is string &&
             msg.content.size() < 10000;
    }

    function isValidDiscussion(data) {
      return data.uid is string &&
             data.subjectId is string &&
             data.messages is list &&
             data.messages.size() <= 1000 &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /discussions/{discussionId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      
      allow create: if isAuthenticated() && 
                    isValidDiscussion(request.resource.data) &&
                    request.resource.data.uid == request.auth.uid;
                    
      allow update: if isAuthenticated() && 
                    isValidDiscussion(request.resource.data) &&
                    (isDocOwner() || isAdmin()) &&
                    request.resource.data.uid == resource.data.uid;
                    
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin();
    }
  }
}
